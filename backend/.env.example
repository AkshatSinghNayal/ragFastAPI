# --- Core ---
ENVIRONMENT=development

# --- PostgreSQL (Render managed) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
# --- Qdrant Cloud ---
QDRANT_URL=https://your-qdrant-instance.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=document_chunks

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- JWT / Auth ---
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (comma-separated, no trailing slash) ---
ALLOWED_ORIGINS=http://localhost:5173

# --- Cookie ---
REFRESH_COOKIE_NAME=refresh_token
# Set COOKIE_SECURE=true in production (HTTPS)
COOKIE_SECURE=false
# Set to "none" when frontend and backend are on different origins (Vercel + Render).
# Requires COOKIE_SECURE=true. Use "lax" or "strict" for same-origin deployments.
COOKIE_SAMESITE=lax

# --- Ingestion tuning ---
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
RAG_TOP_K=5
RAG_HISTORY_MESSAGES=6
